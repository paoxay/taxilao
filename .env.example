MONGODB_URI="mongodb://127.0.0.1:27017/taxilao"
MONGODB_DB="taxilao"
DATABASE_URL="postgresql://taxilao:taxilao_password@localhost:5432/taxilao?schema=public"
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"
ADMIN_ORIGIN="http://localhost:3001"
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
ADMIN_PASSWORD="change-this-admin-password"
DRIVER_PASSWORD="change-this-driver-password"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"
NEXT_PUBLIC_API_URL="http://localhost:4000"
MAPBOX_ACCESS_TOKEN="your-mapbox-access-token"

# Phone OTP signup (Lao Telecom / LTC SMS gateway).
# When these are unset, the API runs in DEV mode: OTP is logged to the console
# and returned as devOtp so you can test without sending real SMS.
LCT_SMS_URL="https://apicenter.laotel.com:9443/api/sms_center/submit_sms"
LTC_SMS_HEADER="TAXILAO"
LCT_SMS_KEY="replace-with-your-lao-telecom-sms-api-key"
